#!/usr/bin/env bash
# Configure nginx to run as nginx user on port 8080

# Fix user in nginx.conf
sed -i 's/^user .*/user nginx;/' /etc/nginx/nginx.conf

# Fix port from 80 to 8080
sed -i 's/listen 80 default_server;/listen 8080 default_server;/g' /etc/nginx/sites-available/default
sed -i 's/listen \[::\]:80 default_server;/listen [::]:8080 default_server;/g' /etc/nginx/sites-available/default

# Fix permissions
chown -R nginx:nginx /var/log/nginx /var/lib/nginx

# Restart nginx as root (it will drop to nginx user automatically)
service nginx restart

# Verify
pgrep -a nginx
